---
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <span class="footer-text">
      <span class="mono">Nivi Ishay</span> · {year} · Learning in public
    </span>
    <div class="footer-links">
      <a href="https://github.com/YOUR_GITHUB" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://linkedin.com/in/YOUR_LINKEDIN" target="_blank" rel="noopener noreferrer">LinkedIn</a>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-line);
    margin-top: 6rem;
  }

  .footer-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 1.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-text {
    font-size: 0.8rem;
    color: var(--color-dim);
  }

  .mono {
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer-links a {
    font-size: 0.8rem;
    color: var(--color-dim);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }
</style>
