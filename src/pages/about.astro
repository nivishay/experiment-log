---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Nivi Ishay" description="About Nivi Ishay">
  <div class="about-page">

    <a href="/" class="back-link">← All experiments</a>

    <div class="about-hero">
      <div class="about-portrait">
        <img src="/niv.jpeg" alt="Niv Ishay" class="portrait-img" />
      </div>
      <div class="about-intro">
        <h1 class="about-title">Niv Ishay</h1>
        <p class="about-role">Software Engineer</p>
        <section class="about-body">
          <p>
            This is my learning log. Every day I pick something I'm curious about,
            build a small project around it, and write up what happened — including
            the parts that didn't work.
          </p>
          <p>
            I'm not here to show off what I already know. I'm here because I genuinely
            enjoy the process of not knowing something, then figuring it out.
          </p>
        </section>
      </div>
    </div>

    <section class="about-links">
      <span class="links-label">Find me</span>
      <div class="links-grid">
        <a href="https://github.com/nivishay" target="_blank" rel="noopener noreferrer" class="link-card">
          <span class="link-icon">⌥</span>
          <div>
            <div class="link-name">GitHub</div>
            <div class="link-sub">github.com/nivishay</div>
          </div>
        </a>
        <a href="https://linkedin.com/in/niv-ishay" target="_blank" rel="noopener noreferrer" class="link-card">
          <span class="link-icon">◈</span>
          <div>
            <div class="link-name">LinkedIn</div>
            <div class="link-sub">linkedin.com/in/niv-ishay</div>
          </div>
        </a>
        <a href="mailto:nivi.ishay@gmail.com" class="link-card">
          <span class="link-icon">✉</span>
          <div>
            <div class="link-name">Email</div>
            <div class="link-sub">nivi.ishay@gmail.com</div>
          </div>
        </a>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .about-page {
    max-width: 820px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-dim);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--color-accent); }

  /* ── Hero layout ───────────────────────── */
  .about-hero {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 3.5rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  .about-portrait {
    position: sticky;
    top: 2rem;
  }

  .portrait-img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: center top;
    border-radius: 4px;
    display: block;
    filter: grayscale(8%);
  }

  .about-intro {
    padding-top: 0.25rem;
  }

  .about-title {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    font-weight: 600;
    color: #1a1a18;
    letter-spacing: -0.02em;
    margin-bottom: 0.25rem;
  }

  .about-role {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-accent);
    margin-bottom: 2rem;
  }

  .about-body {
    border-top: 1px solid var(--color-line);
    padding-top: 1.5rem;
    margin-bottom: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .about-body p {
    font-size: 0.975rem;
    color: var(--color-soft);
    line-height: 1.8;
  }

  @media (max-width: 640px) {
    .about-hero {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .about-portrait {
      position: static;
      max-width: 240px;
    }
  }

  .links-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
  }

  .links-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .link-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-line);
    border-radius: 8px;
    text-decoration: none;
    background: var(--color-surface);
    transition: border-color 0.15s, background-color 0.15s;
  }

  .link-card:hover {
    border-color: var(--color-line-2);
    background-color: var(--color-surface-2);
  }

  .link-icon {
    font-size: 1.1rem;
    color: var(--color-dim);
    width: 24px;
    text-align: center;
  }

  .link-name {
    font-size: 0.875rem;
    font-weight: 500;
    color: #1a1a18;
    margin-bottom: 0.1rem;
  }

  .link-sub {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-dim);
  }
</style>
