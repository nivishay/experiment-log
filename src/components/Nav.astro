---
const navLinks = [
  { href: '/', label: 'Posts' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname;
---

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-brand">
      <span class="nav-name">Niv Ishay</span>
      <span class="nav-slash">/</span>
      <span class="nav-sub">Experiment Log</span>
    </a>

    <div class="nav-links">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`nav-link ${currentPath === link.href ? 'active' : ''}`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://github.com/nivishay"
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link nav-github"
      >
        GitHub ↗
      </a>
    </div>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-line);
    background-color: rgba(250, 250, 248, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: #1a1a18;
    font-size: 0.9rem;
  }

  .nav-name { font-weight: 600; letter-spacing: -0.01em; }
  .nav-slash { color: var(--color-dim); font-weight: 300; }
  .nav-sub { color: var(--color-dim); font-size: 0.8rem; font-family: var(--font-mono); }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.125rem;
  }

  .nav-link {
    padding: 0.35rem 0.7rem;
    border-radius: 6px;
    font-size: 0.875rem;
    color: var(--color-soft);
    text-decoration: none;
    transition: color 0.15s, background-color 0.15s;
  }

  .nav-link:hover { color: #1a1a18; background-color: var(--color-surface-2); }
  .nav-link.active { color: #1a1a18; font-weight: 500; }

  .nav-github {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    margin-left: 0.375rem;
    color: var(--color-dim);
  }

  .nav-github:hover { color: var(--color-accent); background-color: var(--color-accent-soft); }

  @media (max-width: 480px) {
    .nav-sub { display: none; }
    .nav-slash { display: none; }
  }
</style>
