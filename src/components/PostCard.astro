---
import Tag from './Tag.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;

const formatted = date.toLocaleDateString('en-US', {
  month: 'short',
  year: 'numeric',
});
---

<a href={`/posts/${slug}`} class="post-card">
  <div class="post-meta">
    <span class="post-date">{formatted}</span>
    <div class="post-tags">
      {tags.slice(0, 3).map((t) => <Tag label={t} />)}
    </div>
  </div>
  <h2 class="post-title">{title}</h2>
  <p class="post-desc">{description}</p>
  <span class="post-arrow">Read experiment →</span>
</a>

<style>
  .post-card {
    display: block;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--color-line);
    text-decoration: none;
    transition: padding-left 0.2s;
    cursor: pointer;
  }

  .post-card:first-of-type {
    border-top: 1px solid var(--color-line);
  }

  .post-card:hover {
    padding-left: 0.75rem;
  }

  .post-card:hover .post-title {
    color: var(--color-accent);
  }

  .post-card:hover .post-arrow {
    color: var(--color-accent);
    opacity: 1;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-dim);
    letter-spacing: 0.03em;
  }

  .post-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .post-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: #f4f4f5;
    line-height: 1.4;
    letter-spacing: -0.015em;
    margin-bottom: 0.5rem;
    transition: color 0.15s;
  }

  .post-desc {
    font-size: 0.9rem;
    color: var(--color-soft);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .post-arrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-dim);
    opacity: 0.6;
    transition: color 0.15s, opacity 0.15s;
  }
</style>
