---
import BaseLayout from './BaseLayout.astro';
import Tag from '../components/Tag.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  github?: string;
  drivenBy: string;
}

const { title, description, date, tags, github, drivenBy } = Astro.props;

const formatted = date.toLocaleDateString('en-US', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const words = 400;
const readTime = Math.ceil(words / 200);
---

<BaseLayout title={`${title} — Nivi Ishay`} description={description}>
  <article class="post-wrapper">
    <header class="post-header">
      <a href="/" class="back-link">← All experiments</a>

      <div class="post-meta">
        <span class="post-date">{formatted}</span>
        <span class="post-dot">·</span>
        <span class="post-read">{readTime} min read</span>
      </div>

      <h1 class="post-title">{title}</h1>

      <p class="post-desc">{description}</p>

      <div class="post-tags">
        {tags.map((t) => <Tag label={t} />)}
      </div>

      <div class="driven-by">
        <span class="driven-label">What drove me here</span>
        <p class="driven-text">{drivenBy}</p>
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>

    {github && (
      <div class="post-footer">
        <a href={github} target="_blank" rel="noopener noreferrer" class="github-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub ↗
        </a>
      </div>
    )}
  </article>
</BaseLayout>

<style>
  .post-wrapper {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-dim);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--color-accent); }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .post-date, .post-read {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-dim);
  }

  .post-dot { color: var(--color-line-2); }

  .post-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #f4f4f5;
    line-height: 1.3;
    letter-spacing: -0.025em;
    margin-bottom: 1rem;
  }

  .post-desc {
    font-size: 1rem;
    color: var(--color-soft);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }

  .post-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .driven-by {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-left: 2px solid var(--color-accent);
    border-radius: 0 8px 8px 0;
    padding: 1rem 1.25rem;
    margin-bottom: 2.5rem;
  }

  .driven-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.4rem;
  }

  .driven-text {
    font-size: 0.9rem;
    color: var(--color-soft);
    line-height: 1.65;
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-line);
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-soft);
    text-decoration: none;
    transition: color 0.15s;
  }

  .github-link:hover { color: var(--color-accent); }

  @media (max-width: 640px) {
    .post-title { font-size: 1.4rem; }
  }
</style>
