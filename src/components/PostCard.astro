---
import Tag from './Tag.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
  index: number;
  keyInsight: string;
  cover?: string;
}

const { title, description, date, tags, slug, index, keyInsight, cover } = Astro.props;

const formatted = date.toLocaleDateString('en-US', {
  month: 'short',
  year: 'numeric',
});

const num = String(index).padStart(2, '0');
---

<a href={`/posts/${slug}`} class="card">
  <div class="card-body">
    <div class="card-top">
      <div class="card-tags">
        {tags.slice(0, 3).map((t) => <Tag label={t} />)}
      </div>
      <span class="card-date">{formatted}</span>
    </div>

    <h2 class="card-title">{title}</h2>

    <p class="card-insight">{keyInsight}</p>

    <span class="card-cta">Read experiment →</span>
  </div>

  <div class="card-cover">
    {cover
      ? <img src={cover} alt="" class="card-cover-img" />
      : <span class="card-num">#{num}</span>
    }
  </div>
</a>

<style>
  .card {
    display: grid;
    grid-template-columns: 1fr 200px;
    text-decoration: none;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 14px;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .card:hover {
    border-color: var(--color-line-2);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.07);
  }

  .card:hover .card-title { color: var(--color-accent); }
  .card:hover .card-cta { color: var(--color-accent); }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .card-tags { display: flex; gap: 0.375rem; flex-wrap: wrap; }

  .card-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-dim);
    flex-shrink: 0;
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #1a1a18;
    line-height: 1.4;
    letter-spacing: -0.015em;
    margin-bottom: 0.875rem;
    transition: color 0.15s;
    flex: 1;
  }

  .card-insight {
    font-size: 0.85rem;
    color: var(--color-soft);
    line-height: 1.6;
    font-style: italic;
    border-left: 2px solid var(--color-accent);
    padding-left: 0.875rem;
    margin-bottom: 1.25rem;
  }

  .card-cta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-dim);
    transition: color 0.15s;
  }

  .card-cover {
    background: var(--color-surface-2);
    border-left: 1px solid var(--color-line);
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 1rem;
    position: relative;
    overflow: hidden;
  }

  .card-cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(29,158,117,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(29,158,117,0.04) 1px, transparent 1px);
    background-size: 24px 24px;
  }

  .card-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-line-2);
    position: relative;
    z-index: 1;
  }

  .card-cover-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1.5rem;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 600px) {
    .card { grid-template-columns: 1fr; }
    .card-cover { display: none; }
  }
</style>
