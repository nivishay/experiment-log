---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = await getCollection('posts');
const posts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const topics = ['Kubernetes', 'Containers', 'Security', 'ML Infra', 'Linux', 'Benchmarking'];
---

<BaseLayout title="Nivi Ishay — Experiment Log">
  <div class="page">

    <!-- Hero -->
    <section class="hero">
      <div class="hero-orb" />

      <div class="hero-badge">
        <span class="badge-dot" />
        A new experiment every day
      </div>

      <h1 class="hero-name">Niv Ishay</h1>

      <p class="hero-desc">
        A blog where I try things out. Something I read, something I heard about,
        something that seemed cool — I build a small experiment and write up what I found.
      </p>

      <div class="hero-topics">
        {topics.map((t) => (
          <span class="topic-pill">{t}</span>
        ))}
      </div>
    </section>

    <!-- Divider -->
    <div class="section-divider">
      <span class="divider-label">Experiments</span>
      <div class="divider-line" />
      <span class="divider-count">{posts.length}</span>
    </div>

    <!-- Posts grid -->
    {posts.length === 0 ? (
      <p class="empty">First experiment coming soon.</p>
    ) : (
      <div class="posts-grid">
        {posts.map((post, i) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            slug={post.id}
            index={i + 1}
            keyInsight={post.data.keyInsight}
          />
        ))}
      </div>
    )}

  </div>
</BaseLayout>

<style>
  .page {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Hero ──────────────────────────────── */
  .hero {
    position: relative;
    padding: 5.5rem 0 4rem;
    text-align: center;
  }

  .hero-orb {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 400px;
    background: radial-gradient(ellipse at 50% 20%, rgba(0, 212, 255, 0.09) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-soft);
    background: var(--color-surface);
    border: 1px solid var(--color-line-2);
    border-radius: 999px;
    padding: 0.35rem 0.875rem;
    margin-bottom: 1.75rem;
    letter-spacing: 0.02em;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 6px var(--color-accent);
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-name {
    font-size: 3.5rem;
    font-weight: 700;
    letter-spacing: -0.045em;
    line-height: 1;
    margin-bottom: 1.25rem;
    background: linear-gradient(135deg, #ffffff 0%, #a1a1aa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--color-soft);
    line-height: 1.75;
    max-width: 520px;
    margin: 0 auto 2rem;
  }

  .hero-topics {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  .topic-pill {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.3em 0.75em;
    border-radius: 999px;
    background: var(--color-surface-2);
    border: 1px solid var(--color-line);
    color: var(--color-dim);
    letter-spacing: 0.03em;
    transition: color 0.15s, border-color 0.15s;
  }

  .topic-pill:hover {
    color: var(--color-accent);
    border-color: rgba(0, 212, 255, 0.3);
  }

  /* ── Divider ───────────────────────────── */
  .section-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .divider-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: var(--color-line);
  }

  .divider-count {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-line-2);
  }

  /* ── Grid ──────────────────────────────── */
  .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding-bottom: 2rem;
  }

  .empty {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-dim);
    padding: 2rem 0;
    text-align: center;
  }

  @media (max-width: 640px) {
    .hero-name { font-size: 2.4rem; }
    .hero { padding-top: 3.5rem; }
  }
</style>
