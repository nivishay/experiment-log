---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = await getCollection('posts');
const posts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const topics = ['Kubernetes', 'Containers', 'Security', 'ML Infra', 'Linux', 'Benchmarking'];
---

<BaseLayout title="Nivi Ishay — Experiment Log">
  <div class="page">

    <!-- Hero -->
    <section class="hero">
      <div class="hero-orb" />

      <div class="hero-badge">
        <span class="badge-dot" />
        A new experiment every day
      </div>

      <h1 class="hero-name">Niv Ishay</h1>

      <p class="hero-desc">
        A blog where I try things out. Something I read, something I heard about,
        something that seemed cool — I build a small experiment and write up what I found.
      </p>

      <div class="hero-dots">
        <span class="dot" />
        <span class="dot dot-md" />
        <span class="dot dot-lg" />
        <span class="dot dot-md" />
        <span class="dot" />
      </div>
    </section>

    <!-- Divider -->
    <div class="section-divider">
      <span class="divider-label">Experiments</span>
      <div class="divider-line" />
      <span class="divider-count">{posts.length}</span>
    </div>

    <!-- Posts grid -->
    {posts.length === 0 ? (
      <p class="empty">First experiment coming soon.</p>
    ) : (
      <div class="posts-grid">
        {posts.map((post, i) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            slug={post.id}
            index={i + 1}
            keyInsight={post.data.keyInsight}
            cover={post.data.cover}
          />
        ))}
      </div>
    )}

  </div>
</BaseLayout>

<style>
  .page {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Hero ──────────────────────────────── */
  .hero {
    padding: 4rem 0 3.5rem;
    text-align: center;
    border-bottom: 1px solid var(--color-line);
    margin-bottom: 2.5rem;
  }

  .hero-orb { display: none; }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-soft);
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 999px;
    padding: 0.3rem 0.875rem;
    margin-bottom: 1.5rem;
    letter-spacing: 0.03em;
  }

  .badge-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: pulse 2.5s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hero-name {
    font-family: var(--font-serif);
    font-size: 3.75rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 1.25rem;
    color: #1a1a18;
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--color-soft);
    line-height: 1.75;
    max-width: 460px;
    margin: 0 auto 2rem;
  }

  .hero-dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-line-2);
  }

  .dot-md {
    width: 7px;
    height: 7px;
    background: var(--color-dim);
  }

  .dot-lg {
    width: 9px;
    height: 9px;
    background: var(--color-accent);
  }

  /* ── Divider ───────────────────────────── */
  .section-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .divider-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    white-space: nowrap;
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: var(--color-line);
  }

  .divider-count {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-line-2);
  }

  /* ── Grid ──────────────────────────────── */
  .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding-bottom: 3rem;
  }

  .empty {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-dim);
    padding: 2rem 0;
    text-align: center;
  }

  @media (max-width: 640px) {
    .hero-name { font-size: 2.6rem; }
    .hero { padding-top: 2.5rem; }
  }
</style>
