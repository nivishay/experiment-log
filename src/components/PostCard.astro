---
import Tag from './Tag.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
  index: number;
  keyInsight: string;
}

const { title, description, date, tags, slug, index, keyInsight } = Astro.props;

const formatted = date.toLocaleDateString('en-US', {
  month: 'short',
  year: 'numeric',
});

const num = String(index).padStart(2, '0');
---

<a href={`/posts/${slug}`} class="card">
  <div class="card-top">
    <div class="card-tags">
      {tags.slice(0, 3).map((t) => <Tag label={t} />)}
    </div>
    <span class="card-num">#{num}</span>
  </div>

  <h2 class="card-title">{title}</h2>

  <blockquote class="card-insight">
    <span class="insight-mark">"</span>{keyInsight}<span class="insight-mark">"</span>
  </blockquote>

  <div class="card-bottom">
    <span class="card-date">{formatted}</span>
    <span class="card-cta">Read experiment →</span>
  </div>
</a>

<style>
  .card {
    display: block;
    text-decoration: none;
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
    position: relative;
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0, 212, 255, 0.3), transparent);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .card:hover {
    border-color: var(--color-line-2);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(0, 212, 255, 0.08);
  }

  .card:hover::before {
    opacity: 1;
  }

  .card:hover .card-title {
    color: var(--color-accent);
  }

  .card:hover .card-cta {
    color: var(--color-accent);
  }

  /* Top row */
  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .card-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .card-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-line-2);
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  /* Title */
  .card-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: #f4f4f5;
    line-height: 1.4;
    letter-spacing: -0.015em;
    margin-bottom: 1rem;
    transition: color 0.15s;
  }

  /* Key insight */
  .card-insight {
    background: var(--color-surface-2);
    border: 1px solid var(--color-line);
    border-left: 2px solid rgba(0, 212, 255, 0.4);
    border-radius: 0 6px 6px 0;
    padding: 0.75rem 1rem;
    margin-bottom: 1.25rem;
    font-size: 0.845rem;
    color: var(--color-soft);
    line-height: 1.65;
    font-style: italic;
  }

  .insight-mark {
    color: rgba(0, 212, 255, 0.5);
    font-style: normal;
    font-size: 1.1em;
  }

  /* Bottom row */
  .card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-dim);
  }

  .card-cta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-dim);
    transition: color 0.15s;
  }
</style>
